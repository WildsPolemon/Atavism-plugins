# StarNet Core — один корінь, без окремої папки api/
DirectoryIndex index.html install.php index.php

<IfModule mod_rewrite.c>
Options +FollowSymlinks
RewriteEngine On

# Статика: адмін, каса, інсталятор
RewriteRule ^(admin|cashier|install|estore)/ - [L]
RewriteRule ^install\.php$ - [L]

# Захист системних папок
RewriteRule ^(app|vendor|writable|system)/ - [F,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([\s\S]*)$ index.php/$1 [L,NC,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
ErrorDocument 404 index.php
</IfModule>
